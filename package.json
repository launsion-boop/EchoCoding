{
  "name": "echocoding",
  "version": "0.1.13",
  "description": "Immersive audio feedback for Vibe Coding — make your AI coding agent talk, listen, and feel alive",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "echocoding": "dist/bin/echocoding.js",
    "echocoding-hook": "dist/bin/echocoding-hook.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/*.test.ts",
    "dev": "tsx bin/echocoding.ts",
    "clean": "rm -rf dist",
    "postinstall": "bash scripts/build-mic-helper.sh 2>/dev/null || true",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vibe-coding",
    "claude-code",
    "coding-agent",
    "audio-feedback",
    "tts",
    "sound-effects",
    "developer-tools"
  ],
  "author": "EchoClaw",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "sounds/",
    "skills/",
    "src/studio/index.html",
    "tools/mic-helper.swift",
    "scripts/build-mic-helper.sh",
    "scripts/voice-reminder.sh",
    "scripts/voice-ask-nudge.sh",
    "scripts/voice-auto-mode.sh",
    "scripts/auto-start.sh"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/launsion-boop/EchoCoding"
  },
  "homepage": "https://github.com/launsion-boop/EchoCoding",
  "bugs": {
    "url": "https://github.com/launsion-boop/EchoCoding/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "sherpa-onnx-node": "^1.12.38",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
